# Mistral Realms Environment Configuration
# Copy this file to .env and fill in your values

# Mistral AI API Key (Required)
MISTRAL_API_KEY=your_mistral_api_key_here

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production-min-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Settings
COMPOSE_PROJECT_NAME=mistral-realms

# Backend Settings
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend Settings
FRONTEND_PORT=3000

# PostgreSQL Settings
POSTGRES_PASSWORD=realms_password

# Redis Settings
REDIS_PORT=6379

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_THINKING_LEVEL=high

# Alibaba Cloud Qwen API (DashScope)
# Get your API key from: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-max
QWEN_MAX_TOKENS=2048
QWEN_TEMPERATURE=0.7

# Application
CORS_ORIGINS=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Image Generation
# Requires a Mistral account with image generation enabled
ENABLE_IMAGE_GENERATION=false
IMAGE_GENERATION_MAX_PER_HOUR=10
IMAGE_RATE_LIMIT_COOLDOWN=300
# Optional: reuse an existing agent to avoid creating orphans on restart
# MISTRAL_IMAGE_AGENT_ID=
