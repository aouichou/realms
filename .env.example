# Mistral Realms Environment Configuration
# Copy this file to .env and fill in your values

# Mistral AI API Key (Required)
MISTRAL_API_KEY=your_mistral_api_key_here

# Application Settings
COMPOSE_PROJECT_NAME=mistral-realms

# Backend Settings
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend Settings
FRONTEND_PORT=3000

# Redis Settings
REDIS_PORT=6379
