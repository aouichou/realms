# Mistral Realms Backend Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=mistral-realms
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True

# API Server
HOST=0.0.0.0
PORT=8000

# Mistral AI API
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MAX_TOKENS=2048
MISTRAL_TEMPERATURE=0.7

# Gemini AI API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.7
GEMINI_THINKING_LEVEL=high

# OpenAI API (Optional - for fallback)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# Anthropic API (Optional - for fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_MAX_TOKENS=2048
ANTHROPIC_TEMPERATURE=0.7

# Image Generation (uses same API key as above, requires mistral-medium-latest)
ENABLE_IMAGE_GENERATION=true
IMAGE_GENERATION_MAX_PER_HOUR=10
# Optional: Set this to reuse an agent instead of creating new ones on startup
# MISTRAL_IMAGE_AGENT_ID=agent_abc123

# API Base URL (for constructing full image URLs, used by frontend)
API_BASE_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_SECOND=1
RATE_LIMIT_BURST=3

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL Configuration (for later use)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mistral_realms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# CORS
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Logging
LOG_LEVEL=INFO
