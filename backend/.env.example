# Mistral Realms Backend Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=mistral-realms
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True

# API Server
HOST=0.0.0.0
PORT=8000

# Mistral AI API
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MAX_TOKENS=2048
MISTRAL_TEMPERATURE=0.7

# Mistral Toggle (true=demo mode priority 1, false=testing mode priority 99)
MISTRAL_ENABLED=true

# Alibaba Cloud Qwen API (DashScope) - Best for long gameplay tests
# Get your API key from: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your-dashscope-api-key-here
QWEN_MODEL=qwen-max
QWEN_MAX_TOKENS=2048
QWEN_TEMPERATURE=0.7

# ============================================================================
# Free Provider Pool APIs (Phase 4 - RL-153)
# ============================================================================
# These providers offer free tiers and will be used as a fallback pool
# when Mistral/Qwen are unavailable or rate limited

# Groq API - Fast inference with generous free tier
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras API - Super fast inference
# Get your API key from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama-3.3-70b

# Together.ai API - Wide model selection
# Get your API key from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Sambanova API - OpenAI-compatible free tier
# Get your API key from: https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct

# Image Generation (uses same API key as above, requires mistral-medium-latest)
ENABLE_IMAGE_GENERATION=true
IMAGE_GENERATION_MAX_PER_HOUR=10
# Optional: Set this to reuse an agent instead of creating new ones on startup
# MISTRAL_IMAGE_AGENT_ID=agent_abc123

# API Base URL (for constructing full image URLs, used by frontend)
API_BASE_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_SECOND=1
RATE_LIMIT_BURST=3

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL Configuration (for later use)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mistral_realms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# CORS
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# Logging
LOG_LEVEL=INFO
